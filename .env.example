# Host port exposed as SSH.
TENET_PUBLISHED_PORT=2222

# Authentication mode: local or ldap.
TENET_AUTH_MODE=local

# Local mode and registration gateway SSH account created inside the container.
TENET_USER=tenet
TENET_PASSWORD=tenet

# Set to 1 after configuring public keys, or leave 0 for password/LDAP login.
TENET_DISABLE_PASSWORD_AUTH=0

# Allow first LDAP password login to install SSH keys via ssh-copy-id.
TENET_ENABLE_SSH_COPY_ID=1

# Registration gateway: only TENET_REGISTRATION_USER can open the tenet signup flow.
# First connect with `ssh tenet@host` and TENET_PASSWORD,
# then register a tenet account; registered accounts can SSH directly afterward.
TENET_ENABLE_LOCAL_GATEWAY=1
TENET_REGISTRATION_USER=tenet
TENET_LOCAL_GATEWAY_USERS=tenet
TENET_AUTHORIZED_KEYS_DIR=/var/lib/tenet/ssh/authorized_keys.d

# Local mode public key for TENET_USER.
# TENET_AUTHORIZED_KEYS=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... you@example
TENET_AUTHORIZED_KEYS=

# LDAP mode defaults for example.
TENET_LDAP_HOST=ldap.example.org
TENET_LDAP_PORT=389
TENET_LDAP_BASE_DN=DC=example,DC=org
TENET_LDAP_USER_FULLNAME_ATTR=displayName
TENET_LDAP_REFERRALS=0
TENET_LDAP_NETWORK_TIMEOUT=5
TENET_LDAP_OPT_TIMEOUT=5
TENET_LDAP_SEARCH_TIMEOUT=10

# Optional: set these if anonymous LDAP search is not allowed.
TENET_LDAP_BIND_DN=
TENET_LDAP_BIND_PASSWORD=

# tenet app accounts used only when the SSH user is not found in LDAP.
TENET_LOCAL_USER_DB=/var/lib/tenet/users.db
TENET_SYNC_LOCAL_SSH_USERS=1

# Optional: fail container startup unless this LDAP user can be resolved.
TENET_LDAP_TEST_USER=

# Optional SSH restrictions in LDAP mode, for example: TENET_ALLOW_GROUPS=chat
TENET_ALLOW_USERS=
TENET_ALLOW_GROUPS=

TENET_MAX_CLIENTS=64
TZ=Asia/Shanghai

# tenet-bot local AI client.
# For Docker on Linux/macOS/Windows, host.docker.internal points to the host Ollama.
# For local non-Docker runs, use http://127.0.0.1:11434 instead.
TENET_BOT_USERNAME=tenet-bot
TENET_BOT_DISPLAY_NAME=tenet-bot
# Optional. Docker Compose defaults this to /var/lib/tenet/bot-memory.sqlite3.
# TENET_BOT_MEMORY_DB=tenet-bot-memory.sqlite3
TENET_BOT_OLLAMA_URL=http://host.docker.internal:11434
TENET_BOT_CHAT_MODEL=qwen3.5:9b
TENET_BOT_EMBED_MODEL=qwen3-embedding:4b
TENET_BOT_CONTEXT_MESSAGES=50
TENET_BOT_MEMORY_TOP_K=6
TENET_BOT_SUMMARY_THRESHOLD=20
